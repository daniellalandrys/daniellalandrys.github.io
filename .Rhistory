left_join(details, by = "id")
names(tb_joined)
quantile(tb_joined$playingtime, na.rm = TRUE)
quantile(tb_joined$maxplayers, na.rm = TRUE)
# définir le outline
outlier <- 100
outlier2 <- 1000
#filtrer les outllines pour créer un nouveau dataset.
df_clean <- tb_joined %>%
filter(maxplayers < outlier, playingtime < outlier2) %>%
summarise(n = n())
quantile(df_clean$playingtime, na.rm = TRUE)
quantile(df_clean$maxplayers, na.rm = TRUE)
ecdf1 <- ggplot(df_clean, aes(playingtime)) +
stat_ecdf(geom = "step") +
ylab("Pourcentage") +
xlab("Temps de jeu en minutes")
ecdf1 + scale_x_continuous(breaks=seq(0,1000,100))
View(df_clean)
